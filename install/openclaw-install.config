# OpenClaw installer config
# ---------------------------------------------------------------------------
# Both install-openclaw.ps1 and install-openclaw.sh read this file by default
# (alongside the script). Override by passing --config / -ConfigFile.
#
# Format: key=value, one per line. Lines starting with # are comments.
# CLI flags always override values set here.

# How to install OpenClaw.
#   npm     - global npm install (recommended on Windows)
#   oneline - run the official install.sh one-liner (recommended on Unix)
#   git     - clone the repo as a pnpm workspace (for hacking on it)
method=npm

# Used only when method=git. Tilde is expanded.
install_dir=~/openclaw

# Skip the interactive `openclaw onboard` step at the end.
skip_onboard=false

# Reinstall / re-clone even if OpenClaw is already present.
force=false

# Minimum Node.js major version required.
min_node_major=20

# Auto-install Node.js if missing or too old.
# false will abort with instructions instead of installing.
auto_install_node=true

# Release channel for `openclaw update --channel <value>` after install.
# Leave blank to skip switching channels.
#   stable - default release line
#   dev    - bleeding edge
channel=

# Optional: extra arguments appended to `openclaw onboard`.
# e.g. onboard_args=--non-interactive
onboard_args=--non-interactive

# ---------------------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------------------
# These get exported as environment variables before `openclaw onboard`,
# so the onboarding flow picks them up instead of prompting you.
#
# SECURITY: this file now contains credentials. Keep it readable only by you:
#   Linux/macOS:  chmod 600 openclaw-install.config
#   Windows:      icacls openclaw-install.config /inheritance:r /grant:r "%USERNAME%:F"
# The installer will warn if the file is group/world-readable on Unix.
# Leave any value blank to skip it (OpenClaw will prompt during onboarding).
#
# An existing exported env var of the same name is NOT overwritten; the
# config value is used only when the env var is empty.

anthropic_api_key=
openai_api_key=
telegram_bot_token=
